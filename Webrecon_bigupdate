import sys
import os
import ssl
import socket
import threading
import requests
from bs4 import BeautifulSoup
from datetime import datetime
import customtkinter as ctk

ctk.set_appearance_mode("dark")
ctk.set_default_color_theme("blue")

class NeonScannerApp(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.title("NEON RECON SCANNER v1.1")
        self.geometry("850x600")
        self.resizable(True, True)
        self.CYAN = "#00f0ff"
        self.PINK = "#ff007f"
        self.DARK_BG = "#0a0a12"
        self.PANEL_BG = "#121224"
        self.configure(fg_color=self.DARK_BG)
        self.create_widgets()

    def create_widgets(self):
        self.title_label = ctk.CTkLabel(
            self, 
            text="TOTAL RECON SCANNER", 
            font=ctk.CTkFont(family="Courier New", size=28, weight="bold"),
            text_color=self.CYAN
        )
        self.title_label.pack(pady=15)

        self.input_frame = ctk.CTkFrame(self, fg_color=self.PANEL_BG, border_color=self.PINK, border_width=1)
        self.input_frame.pack(fill="x", padx=20, pady=10)

        self.url_entry = ctk.CTkEntry(
            self.input_frame, 
            placeholder_text="Enter target URL (e.g., example.com)",
            width=500,
            font=ctk.CTkFont(size=14),
            fg_color="#1a1a2e",
            text_color="#ffffff",
            border_color=self.CYAN
        )
        self.url_entry.pack(side="left", padx=15, pady=15, expand=True, fill="x")
        self.url_entry.bind("<Return>", lambda event: self.start_scan_thread())

        self.scan_button = ctk.CTkButton(
            self.input_frame, 
            text="LAUNCH SCAN", 
            font=ctk.CTkFont(weight="bold"),
            fg_color=self.PINK,
            hover_color="#cc0066",
            text_color="#ffffff",
            command=self.start_scan_thread
        )
        self.scan_button.pack(side="right", padx=15, pady=15)

        self.result_text = ctk.CTkTextbox(
            self, 
            font=ctk.CTkFont(family="Courier New", size=13),
            fg_color="#05050a",
            text_color="#00ff66",
            border_color=self.CYAN,
            border_width=1
        )
        self.result_text.pack(fill="both", expand=True, padx=20, pady=15)
        self.result_text.insert("0.0", "[+] System ready. Awaiting target...\n")
        self.result_text.configure(state="disabled")

        self.status_label = ctk.CTkLabel(
            self, 
            text="STATUS: IDLE", 
            font=ctk.CTkFont(family="Courier New", size=11),
            text_color=self.CYAN
        )
        self.status_label.pack(side="bottom", anchor="w", padx=25, pady=5)

    def log_to_gui(self, message):
        self.result_text.configure(state="normal")
        self.result_text.insert("end", message + "\n")
        self.result_text.see("end")
        self.result_text.configure(state="disabled")

    def get_ssl_expiry(self, hostname):
        try:
            context = ssl.create_default_context()
            with socket.create_connection((hostname, 443), timeout=5) as sock:
                with context.wrap_socket(sock, server_hostname=hostname) as ssock:
                    cert = ssock.getpeercert()
                    expiry = datetime.strptime(cert['notAfter'], '%b %d %H:%M:%S %Y %Z')
                    return str(expiry)
        except Exception:
            return "N/A (SSL Error)"

    def start_scan_thread(self):
        target = self.url_entry.get().strip()
        if not target:
            return
        if target.lower() == 'exit':
            self.destroy()
            return
        if not target.startswith("http"):
            target = "https://" + target
        self.scan_button.configure(state="disabled", text="SCANNING...")
        self.status_label.configure(text="STATUS: SCANNING IN PROGRESS...", text_color=self.PINK)
        threading.Thread(target=self.run_scan, args=(target,), daemon=True).start()

    def run_scan(self, url):
        hostname = url.split("://")[-1].split("/")[0]
        clean_hostname = hostname.replace(":", "_")
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        filename = f"report_{clean_hostname}_{timestamp}.txt"
        report_lines = []
        
        def print_both(text):
            self.log_to_gui(text)
            report_lines.append(text)

        print_both("\n" + "="*60)
        print_both(f"TOTAL RECON SCANNER - ANALYSIS: {url}")
        print_both("="*60)

        headers = {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/119.0.0.0 Safari/537.36'
        }

        try:
            ssl_date = self.get_ssl_expiry(hostname)
            print_both(f"[*] SSL certificate valid until: {ssl_date}")
            
            response = requests.get(url, headers=headers, timeout=10)
            soup = BeautifulSoup(response.text, 'html.parser')
            
            print_both("\n[*] Checking security headers:")
            sec_headers = ['X-Frame-Options', 'Content-Security-Policy', 'Strict-Transport-Security']
            for h in sec_headers:
                status = "OK" if h in response.headers else "MISSING"
                print_both(f"    - {h}: {status}")
                
            print_both("\n[*] Analyzing Cookies / Spy & Tracking Risk:")
            cookies = response.cookies
            if not cookies:
                print_both("    [+] No cookies set by this response.")
            else:
                print_both(f"    [!] Found {len(cookies)} cookies. Analyzing flags...")
                for cookie in cookies:
                    print_both(f"    -> Cookie Name: '{cookie.name}'")
                    has_httponly = 'httponly' in [k.lower() for k in cookie._rest.keys()]
                    if not has_httponly and not cookie.secure:
                        print_both(f"       [CRITICAL] High Spy Risk! Missing HttpOnly & Secure flags.")
                    else:
                        if not has_httponly:
                            print_both(f"       [WARNING] Missing HttpOnly flag (vulnerable to XSS theft).")
                        if not cookie.secure:
                            print_both(f"       [WARNING] Missing Secure flag (transmitted over plaintext HTTP).")
                        if has_httponly and cookie.secure:
                            print_both(f"       [OK] Cookie is securely configured.")

            scripts = soup.find_all('script')
            js_files = [s.get('src') for s in scripts if s.get('src')]
            print_both(f"\n[+] Found {len(js_files)} JavaScript files:")
            if js_files:
                for i, js in enumerate(js_files, 1):
                    full_js_url = js if js.startswith('http') else url.rstrip('/') + '/' + js.lstrip('/')
                    print_both(f"    {i}. {full_js_url}")
            else:
                print_both("    - No external JS files found.")
                
        except Exception as e:
            print_both(f"[-] Scan error: {e}")
        finally:
            try:
                with open(filename, "w", encoding="utf-8") as f:
                    f.write("\n".join(report_lines))
                print_both(f"\n[+] Report saved to: {filename}")
            except Exception as file_err:
                print_both(f"[-] Failed to save file: {file_err}")

            self.scan_button.configure(state="normal", text="LAUNCH SCAN")
            self.status_label.configure(text="STATUS: FINISHED", text_color=self.CYAN)

if __name__ == "__main__":
    app = NeonScannerApp()
    app.mainloop()
